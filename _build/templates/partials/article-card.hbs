<a class="card" href="{{url}}">
  <div class="card-img-wrap">
    <img src="{{image}}" alt="{{imageAlt}}" loading="lazy" width="600" height="400">
    <div class="card-overlay" aria-hidden="true">
      <span class="card-read-more">Read Guide →</span>
    </div>
  </div>
  <div class="card-body">
    {{#if tag}}<span class="card-tag">{{tag}}</span>{{/if}}
    <h3>{{title}}</h3>
    <p>{{excerpt}}</p>
  </div>
</a>
