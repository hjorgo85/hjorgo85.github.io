<header class="site-header" id="site-header">
  <div class="container nav">
    <a href="/" class="logo">
      {{icon "fish"}}
      <span>{{site.logoText}}</span>
    </a>
    <ul class="nav-links" id="primary-nav" role="list">
      {{#each site.nav}}
      <li><a href="{{this.url}}"{{#if (eq this.url ../url)}} aria-current="page"{{/if}}>{{this.label}}</a></li>
      {{/each}}
    </ul>
    <button class="nav-toggle" type="button" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-nav">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
</header>

<!-- Mobile navigation overlay -->
<div class="mobile-nav-overlay" id="mobile-nav" role="dialog" aria-modal="true" aria-label="Navigation menu" aria-hidden="true">
  <div class="mobile-nav-panel">
    <div class="mobile-nav-header">
      <a href="/" class="logo" tabindex="-1">
        {{icon "fish"}}
        <span>{{site.logoText}}</span>
      </a>
      <button class="mobile-nav-close" aria-label="Close navigation menu" tabindex="-1">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <ul class="mobile-nav-links" role="list">
      {{#each site.nav}}
      <li>
        <a href="{{this.url}}"{{#if (eq this.url ../url)}} aria-current="page"{{/if}} tabindex="-1">
          {{this.label}}
        </a>
      </li>
      {{/each}}
    </ul>
    <div class="mobile-nav-footer">
      <p>Practical fishkeeping guides, free forever.</p>
    </div>
  </div>
</div>
